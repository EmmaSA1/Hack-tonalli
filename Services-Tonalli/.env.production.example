# ─────────────────────────────────────────────────────────────────────────────
# Tonalli — Production Environment Variables
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to version control.
# Admin secret key must come from HSM/KMS, not this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=<your-rds-or-mysql-host>
DB_PORT=3306
DB_USER=<db-user>
DB_PASS=<db-password>
DB_NAME=tonalli

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=<strong-random-secret-min-64-chars>
JWT_EXPIRES_IN=7d

# ── Stellar / Soroban (Mainnet) ───────────────────────────────────────────────
STELLAR_NETWORK=mainnet
STELLAR_HORIZON_URL=https://horizon.stellar.org
STELLAR_SOROBAN_URL=https://mainnet.stellar.validationcloud.io/v1/XLM

# Admin keypair — load from HSM/KMS at runtime, do NOT hardcode here
# Example: inject via AWS Secrets Manager, HashiCorp Vault, or GCP Secret Manager
STELLAR_ADMIN_PUBLIC=<admin-stellar-public-key>
STELLAR_ADMIN_SECRET=<LOAD-FROM-HSM-KMS-NOT-HERE>

# Reward pool wallet (can be same as admin or a dedicated wallet)
REWARD_POOL_SECRET=<LOAD-FROM-HSM-KMS-NOT-HERE>

# ── Deployed Contract IDs (populated by deploy.sh) ───────────────────────────
NFT_CONTRACT_ID=<from-.env.contracts.mainnet>
REWARDS_CONTRACT_ID=<from-.env.contracts.mainnet>
PODIUM_NFT_CONTRACT_ID=<from-.env.contracts.mainnet>
TOKEN_CONTRACT_ID=<from-.env.contracts.mainnet>
XLM_SAC_ADDRESS=CAS3J7GYLGXMF6TDJBBYYSE3HQ6BBSMLNUQ34T6TZMYMW2EVH34XOWMA

# ── ACTA SDK ──────────────────────────────────────────────────────────────────
ACTA_API_KEY=<your-production-acta-api-key>
ACTA_NETWORK=mainnet

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://tonalli.app,https://www.tonalli.app
