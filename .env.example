# ==============================================
# TONALLI - Environment Configuration Template
# ==============================================
# Copy this file to .env and update with your values
# cp .env.example .env

# ----------------------------------------------
# Application Environment
# ----------------------------------------------
NODE_ENV=development
# Options: development, production, test

# ----------------------------------------------
# Backend Configuration
# ----------------------------------------------
BACKEND_PORT=3001
# Port where the NestJS backend will run

# ----------------------------------------------
# Database Configuration
# ----------------------------------------------
DB_TYPE=postgres
# Options: postgres, mysql
DB_HOST=postgres
# Use 'postgres' for Docker, 'localhost' for local development
DB_PORT=5432
# Default: 5432 for PostgreSQL, 3306 for MySQL
DB_USER=tonalli
DB_PASS=tonalli_password
# IMPORTANT: Change this password in production!
DB_NAME=tonalli
DB_LOGGING=false
# Enable database query logging for debugging

# ----------------------------------------------
# Redis Configuration
# ----------------------------------------------
REDIS_HOST=redis
# Use 'redis' for Docker, 'localhost' for local development
REDIS_PORT=6379

# ----------------------------------------------
# JWT Authentication
# ----------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# CRITICAL: Generate a strong random secret for production
# Example: openssl rand -base64 64
JWT_EXPIRES_IN=7d
# Token expiration time (e.g., 1h, 7d, 30d)

# ----------------------------------------------
# Stellar Blockchain Configuration
# ----------------------------------------------
STELLAR_NETWORK=testnet
# Options: testnet, mainnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org

# Stellar Account Configuration (Optional)
# STELLAR_PUBLIC_KEY=your_stellar_public_key
# STELLAR_SECRET_KEY=your_stellar_secret_key

# ----------------------------------------------
# ACTA SDK Configuration (for certificates)
# ----------------------------------------------
# ACTA_API_KEY=your_acta_api_key
# ACTA_ENVIRONMENT=testnet

# ----------------------------------------------
# Web Frontend Configuration
# ----------------------------------------------
WEB_PORT=5173
# Port where the Vite dev server will run

VITE_API_URL=http://localhost:3001/api
# Backend API URL for the frontend
# For Docker: http://backend:3001/api
# For local: http://localhost:3001/api

VITE_STELLAR_NETWORK=testnet
# Must match STELLAR_NETWORK

# ----------------------------------------------
# Email Configuration (Optional)
# ----------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@tonalli.app

# ----------------------------------------------
# File Upload Configuration (Optional)
# ----------------------------------------------
# MAX_FILE_SIZE=5242880
# File size in bytes (default: 5MB)
# UPLOAD_DEST=./uploads

# ----------------------------------------------
# Logging Configuration
# ----------------------------------------------
# LOG_LEVEL=info
# Options: error, warn, info, debug, verbose

# ----------------------------------------------
# CORS Configuration
# ----------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# Comma-separated list of allowed origins

# ----------------------------------------------
# Rate Limiting (Optional)
# ----------------------------------------------
# THROTTLE_TTL=60
# Time window in seconds
# THROTTLE_LIMIT=10
# Max requests per TTL window

# ----------------------------------------------
# Database Connection Pool (Optional)
# ----------------------------------------------
# DB_CONNECTION_LIMIT=10
# DB_CONNECTION_TIMEOUT=30000

# ----------------------------------------------
# Security Headers (Production)
# ----------------------------------------------
# HELMET_ENABLED=true
# CSP_ENABLED=true

# ----------------------------------------------
# Development Tools
# ----------------------------------------------
# ENABLE_SWAGGER=true
# Enable API documentation at /api/docs
# ENABLE_PLAYGROUND=true
# Enable GraphQL playground (if using GraphQL)
